# Install the following required packages if not already installed
# install.packages("plotly")
# install.packages("orca")
# Load required packages
library(plotly)
library(orca)
# Define protein state labels and make them a factor to control bar order
State <- factor(
c("Inward-Open", "Outward-Open", "Outward-Occluded"),
levels = c("Inward-Open", "Outward-Open", "Outward-Occluded")  # ensures bar order: left to right
)
# Define normalized Ni accessibility values for each state
DDM_Ni <- c(0.362, 1, 0.101)
# Create data frame for plotting
data <- data.frame(State, DDM_Ni)
# Create the bar plot using plot_ly
fig <- plot_ly(
data,
x = ~State,        # x-axis categories
y = ~DDM_Ni,       # y-axis values
type = 'bar',      # bar chart
width = 0.4,       # bar width (smaller = thinner bars)
name = 'DDM',      # trace name (legend label, if shown)
marker = list(     # styling for the bars
color = '#7884bc',          # bar fill color
line = list(
color = 'black',          # outline color
width = 2                 # outline thickness (thicker for emphasis)
)
)
)
# Customize layout of the plot
fig <- fig %>% layout(
title = '',        # no main title
font = list(
family = 'Harding Text Web',  # custom font (must be installed on system)
color = 'black'               # default font color
),
xaxis = list(
title = "",       # no x-axis title
tickfont = list(
family = 'Harding Text Web',  # font for x-axis labels
size = 15,                    # font size
color = 'black'               # label color
),
showline = TRUE,     # show the x-axis line
linecolor = 'black', # x-axis line color
linewidth = 1,       # x-axis line thickness
showgrid = FALSE     # remove vertical grid lines
),
yaxis = list(
title = 'Normalised Solvent (Ni-EDDA) Accessibility (Π)',  # y-axis label
titlefont = list(
family = 'Harding Text Web',  # font for y-axis title
size = 17,                    # font size
color = 'black'               # color
),
tickfont = list(
family = 'Harding Text Web',  # font for y-axis ticks
size = 15,
color = 'black'
),
showline = TRUE,     # show the y-axis line
linecolor = 'black',
linewidth = 1,
showgrid = FALSE     # remove horizontal grid lines
),
legend = list(
x = 0, y = 1,         # position legend top-left
font = list(
family = 'Harding Text Web',  # legend font
size = 13,
color = 'black'
),
bgcolor = 'rgba(255, 255, 255, 0)',   # transparent background
bordercolor = 'rgba(255, 255, 255, 0)' # no border
),
barmode = 'group',       # group bars if multiple traces (only one here)
bargap = 0.4,            # spacing between groups
bargroupgap = 0.2        # spacing within group (not relevant here)
)
# Render the interactive plot
fig
# Save the Plotly chart as an SVG file
orca(fig, "ni_accessibility_plot.svg")
